<h1>Events</h1>

<!-- 🔐 Auth Section -->
<div style="margin-bottom: 20px;">
  <% if clerk.session %>
    <p>
      Logged in as:
      <strong><%= clerk.user.email_addresses.first.email_address %></strong>
    </p>

    <!-- ✅ FIXED LOGOUT -->
    <button onclick="handleLogout()">Logout</button>

  <% else %>
    <!-- ✅ Clerk Hosted Login -->
    <a href="https://causal-yeti-65.accounts.dev/sign-in">Login</a> |
    <a href="https://causal-yeti-65.accounts.dev/sign-up">Sign Up</a>
  <% end %>
</div>

<!-- ✅ Logout Script -->
<script>
  async function handleLogout() {
    await Clerk.load();

    await Clerk.signOut();

    // 🔥 IMPORTANT: force full reload
    window.location.reload();
  }
</script>

<hr>

<!-- 📅 Events List -->
<% @events.each do |event| %>
  <div style="border:1px solid #ccc; padding:15px; margin-bottom:15px; border-radius:8px;">

    <h3><%= event.title %></h3>

    <p>
      <strong>Date:</strong>
      <%= event.start_date.strftime("%d %b %Y %I:%M %p") %>
    </p>

    <% if event.image_url.present? %>
      <img src="<%= event.image_url %>" width="300">
    <% end %>

    <p>
      <%= truncate(event.description, length: 150) %>
    </p>

    <!-- 🔢 Vote Count -->
    <p>
      <strong>Votes:</strong>
      <%= vote_count(event) %>
    </p>

    <!-- 👍 Voting -->
    <% if clerk.session %>

      <!-- ✅ FIXED FORM (helper + turbo off) -->
      <form action="<%= upvote_event_path(event) %>" method="post" data-turbo="false" style="display:inline;">
        <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
        <button type="submit">👍 Upvote</button>
      </form>

      <form action="<%= downvote_event_path(event) %>" method="post" data-turbo="false" style="display:inline;">
        <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
        <button type="submit">👎 Downvote</button>
      </form>

    <% else %>
      <p style="color: gray;">Login to vote</p>
    <% end %>

  </div>
<% end %>